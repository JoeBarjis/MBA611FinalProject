      <column datatype='string' name='[Booking Status]' role='dimension' type='nominal' />
      <column caption='Ride Distance (Cleaned)' datatype='string' name='[Calculation_1275748349235206]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([Ride Distance]) THEN &quot;Unknown&quot;&#10;ELSE STR(INT([Ride Distance]))&#10;END' />
      </column>
      <column caption='flag_vehicle' datatype='string' name='[Calculation_1275748645281801]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Vehicle Type] = &apos;Bike&apos; THEN &apos;FOCUS&apos; ELSE &apos;Context&apos; END' />
